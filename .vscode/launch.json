{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "deco-sae Train (Single GPU Debug)",
            "type": "debugpy",
            "request": "launch",
            "module": "torch.distributed.run",
            "args": [
                "--nproc_per_node=1",
                "deco-sae/train_sae.py",
                "--config",
                "deco-sae/dinov2_base_sae_vit_decoder.yaml"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "TORCH_HOME": "/cpfs01/huangxu/.cache/torch"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "deco-sae Train (8 GPU, run.sh)",
            "type": "debugpy",
            "request": "launch",
            "module": "torch.distributed.run",
            "args": [
                "--nproc_per_node=8",
                "deco-sae/train_sae.py",
                "--config",
                "deco-sae/dinov2_base_sae_flow_matching.yaml"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "TORCH_HOME": "/cpfs01/huangxu/.cache/torch"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "DINOv2 DiT Training (Single GPU)",
            "type": "debugpy",
            "request": "launch",
            "program": "/cpfs01/huangxu/miniconda3/envs/sae/bin/torchrun",
            "args": [
                "--nproc_per_node=1",
                "--nnodes=1",
                "--node_rank=0",
                "--master_addr=localhost",
                "--master_port=29500",
                "projects/rae/train.py",
                "--config", "projects/rae/configs/stage2/training/ImageNet256/DiTDH-XL_DINOv2-B.yaml",
                "--data-path", "/cpfs01/huangxu/ILSVRC/Data/CLS-LOC/train/",
                "--results-dir", "./result_dit/result_dinov2_GAN0p75_VF0p75_30000_layernorm_test",
                "--global-batch-size", "8",
                "--vae-ckpt", "results_vae/dinov2_base_vit_decoder_GAN0p75_VF0p75_layernorm/step_30000.pth",
                "--decoder-type", "vit_decoder",
                "--encoder-type", "dinov2",
                "--dinov2-model-name", "/cpfs01/huangxu/models/dinov2-register-base",
                "--global-seed", "1031",
                "--cfg-prob", "0.1",
                "--precision", "bf16",
                "--noise-schedule", "log_norm",
                "--log-norm-mean", "0.5",
                "--log-norm-std", "1.0",
                "--fid-every", "25000",
                "--fid-ref-path", "VIRTUAL_imagenet256_labeled.npz",
                "--fid-batch-size", "64",
                "--vae-use-ema",
                "--skip-to-moments",
                "--denormalize-decoder-output"
            ],
            "env": {
                "TORCH_HOME": "/cpfs01/huangxu/.cache/torch",
                "WANDB_DISABLED": "true",
                "OMP_NUM_THREADS": "4",
                "NCCL_IB_DISABLE": "0",
                "NCCL_SOCKET_IFNAME": "eth0",
                "GLOO_SOCKET_IFNAME": "eth0",
                "NCCL_IB_HCA": "mlx5_100,mlx5_101,mlx5_102,mlx5_103,mlx5_104,mlx5_105,mlx5_106,mlx5_107",
                "NCCL_IB_GID_INDEX": "7"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}
